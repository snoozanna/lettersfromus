:: listaudio [nobr]
<<set _list to $audiodata.filter(a => a && a.theme === $theme)>>

<div class="audio-btn-container">

<<for _audio range _list>>
  <<capture _audio>>
  <div class="audio-btn">
  <img src="assets/img/play.png">

  <<button _audio.audioName>>
    <<set $currentAudio to _audio>>
    <<set $prevpass to $currentAudio.theme>>
    <<goto "listen">>

  <</button>>
  </div>
  <</capture>>
<</for>>

</div>


