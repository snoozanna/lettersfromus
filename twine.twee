:: headerlisten [nobr]
<header class="listen player" >

<div class="logo-container"><img src="../assets/img/title.png"/></div>

</header>



:: listen [nobr t8n.typewriter.4 t8n-dissolve]

/* might need to put this in prev pass
<<set $captions to false>>
<<set $sound to true>>
<<set $showMenu to true>>
<<set $menuOpen to false>> */

<<set $showCaptionsIcon to true>>
<<set $showAudioIcon to true>>
<<set $showBackwards to true>>
/* <<set $sound to true>> */
<<set $showMenu to false>>
<<set $menuOpen to false>>


<<set $passage to "listen">>



<<include "headerlisten">>

<main class="main-section listen player " id="main">
<audio id="audioPlayer" autoplay>

</audio>

<<if $captions is true>>
  
<p id="caption">

</p>
  <<include `$currentAudio.audioSrc + "-cap"`>>
<</if>>

</main>
<<include "footerlisten">>



<<done>>
  <<timed 0.1s>>
<<if $sound is true>>
<<set $a to setup.chooseStoryAudio()>>
  <</if>>
  <</timed>>
  <</done>>


:: footerlisten [nobr]

<footer>
<div class="nav-container">
  <<if $showBackwards is true>>
    <div class="nav-wrapper">
      <div class="nav-item">
      <<button "Back">>
          <<goto $prevpass>>
          <</button>>
      </div>
    </div>
    <</if>>
  <<if $showCaptionsIcon is true>>
  <div class="nav-wrapper">
      <div class="nav-item " id="capIconContainer">
      
 
        <<if $captions is true>>
           <<button "Captions On">>
          <<set $captions to false>>
           <<goto $passage>>
          <</button>>
       <<else>>
         <<button "Captions Off">>
           <<set $captions to true>>
  
             <<goto $passage>>
          <</button>>
          <</if>>

  </div>
    </div>
  <</if>> 


  
  <div class="nav-wrapper">
      <div class="nav-item" id="audioContainer">
    
    <<if $sound is true>>
         <<button "Audio On">>
        <<set $sound to false>>
        <<goto $passage>>
        <</button>>
 
    <</if>>
     <<if $sound is false>>
      <<button "Audio Off">>
            <<set $sound to true>>
            <<goto $passage>>
             <</button>>
    
    <</if>>

  </div>
    </div>

</div>

</footer>

<<done>>
  <<if $captions is true>>
    <<addclass "#capIconContainer" "activeIcon">>
  <</if>>
  <<if $sound is true>>
   <<addclass "#audioContainer" "activeIcon">>
  <</if>>
<</done>>

:: prerecord [nobr]
<<set $prevpass to "map">>
<<set $passage to "prerecord">>
<<set $nextpass to "record">>

<main class="about">
<h1>Record your story</h1>
<p>Tell us about you, your favourite place in Islington, something that brings you joy, or rage, or simply something about Islington’s history others may not know about.</p>
<<button "Record">>
  <<goto "record">>
  <</button>>

</main>

<<include "footer">>

:: record [nobr]
<<set $prevpass to "prerecord">>
<<set $passage to "record">>

<main class="about">
<h1>Record</h1>
    <iframe src="https://www.speakpipe.com/widget/inline/2iawuy25u8ynlcssocfc003zmfcl529u" allow="microphone" width="100%" height="200" frameborder="0"></iframe>
