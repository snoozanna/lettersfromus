            <</timed>>
        <</link>>
    </div>

    <div class="hotspot joy">
        <<link "">>
            <<set $theme to "joy">>
            <<removeclass ".overlay" "active">>
            <<addclass "#joy" "active">>
            <<timed 0.5s>>
                <<goto "joy">>
            <</timed>>
        <</link>>
    </div>

    <div class="hotspot people">
        <<link "">>
            <<set $theme to "people">>
            <<removeclass ".overlay" "active">>
            <<addclass "#people" "active">>
            <<timed 0.5s>>
                <<goto "people">>
            <</timed>>
        <</link>>
    </div>

    <div class="hotspot places">
        <<link "">>
            <<set $theme to "places">>
            <<removeclass ".overlay" "active">>
            <<addclass "#places" "active">>
            <<timed 0.5s>>
                <<goto "places">>
            <</timed>>
        <</link>>
    </div>

    <div class="hotspot rage">
        <<link "">>
            <<set $theme to "rage">>
            <<removeclass ".overlay" "active">>
            <<addclass "#rage" "active">>
            <<timed 0.5s>>
                <<goto "rage">>
            <</timed>>
        <</link>>
    </div>

</div>

</main>

<<include "footermap">>

:: listaudio [nobr]
