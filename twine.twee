:: intro [nobr]
<<set $prevpass to "landing">>
<<set $passage to "intro">>
<<set $nextpass to "map">>
<<set $showLogo to false>>
<<set $showMenu to false>>
<<set $menuOpen to false>>
<audio id="audio" autoplay></audio>

<<if $sound is true>>
  <<timed 0.1s>>
    <<replace "#audio">><source  src="../assets/sound/DJIntro.mp3"><</replace>> 
  <</timed>>
  <</if>>
  <<include "header">>
<main id="main"> 
 <div class="main-container text">
 <h1>Letters from us</h1>
   <div id="textMount"></div>
  <p> <span class="project">Letters from Us</span> is an interactive audio archive celebrating the everyday stories of the people of Islington. </p>

<p>It was created by <a href="https://www.koro.org.uk/" rel="noreferrer" target="_blank" class="highlighted">Koro</a>, in partnership with City St George’s, University of London, Highbury Roundhouse, Mildmay Community Centre and St Mary Magdalene Academy. </p>

<p>This is a growing, living archive. Listen in, then leave your own story behind. </p>

       <<button "Enter">><<goto $nextpass>><</button>>
   
 
   
 </div>
</main>
<<include "footer">>




