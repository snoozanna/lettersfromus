:: landing [nobr]
<<set $prevpass to "landing">>
<<set $passage to "landing">>
<<set $nextpass to "intro">>
<<set $sound to true>>
<<set $captions to true>>

<main class="landing">

  <div class="landing-character-container">

    <div class="char-wrapper relax">
      <img src="assets/img/characters/characters-27.png" alt="Relaxing">
    </div>

    <div class="char-wrapper skater">
      <img src="assets/img/characters/characters-24.png" alt="Skater">
    </div>

    <div class="char-wrapper duo">
      <img src="assets/img/characters/duo.png" alt="Duo">
    </div>

    <div class="char-wrapper couple">
      <img src="assets/img/characters/oldcouple.png" alt="Elderly couple">
    </div>

    <div class="btn-container title-wrapper">
      <h1 class="title">Letters from us</h1>

      <div class="subtitle">
        <span>An online archive of</span>
        <span>Islington voices</span>
      </div>

      <<button "Start">>
        <<goto $nextpass>>
      <</button>>
    </div>

  </div>

</main>

:: intro [nobr]
<<set $prevpass to "landing">>
<<set $passage to "intro">>
<<set $nextpass to "map">>
<<set $showLogo to false>>
<<set $showMenu to false>>
<<set $menuOpen to false>>
<audio id="audio" autoplay></audio>

<<if $sound is true>>
  <<timed 0.1s>>
    <<replace "#audio">><source  src="../assets/sound/DJIntro.mp3"><</replace>> 
  <</timed>>
  <</if>>
  <<include "header">>
<main id="main"> 
 <div class="main-container text">
 <h1 class="title">Letters from us</h1>
   <div id="textMount"></div>
  <p> <span class="project">Letters from Us</span> is an interactive audio archive celebrating the everyday stories of the people of Islington. </p>

<p>It was created by <a href="https://www.koro.org.uk/" rel="noreferrer" target="_blank" class="highlighted">Koro</a>, in partnership with City St George’s, University of London, Highbury Roundhouse, Mildmay Community Centre and St Mary Magdalene Academy. </p>

<p>This is a growing, living archive. Listen in, then leave your own story behind. </p>

       <<button "Enter">><<goto $nextpass>><</button>>
   
 
   
 </div>
</main>
<<include "footer">>




:: loading [nobr t8n.typewriter.4]
<main id="main" class="main-section loading">
<<type 200ms>><h3 class="loading">Loading...</h3><</type>>
<<timed 6s>>
<<goto $nextpass>>
<</timed>>
</main>


:: map [nobr]
<<set $prevpass to "intro">>
<<set $passage to "map">>
<<set $nextpass to "">>

<main class="main-map">
<br/>
<div class="map-instruction">
<h1>Letters from us</h1>
<span>Click on the words on the map to listen to the archive</span></div>
<div class="img-wrapper">

    <!-- Base map -->
    <img class="bg-map" src="../assets/img/map/isborough.png">
    <img class="base-map" src="../assets/img/map/b_w_small.png">

    <!-- COLOUR OVERLAYS -->
    <img id="community" class="overlay" src="../assets/img/map/community.png">
    <img id="history" class="overlay" src="../assets/img/map/history.png">
    <img id="joy" class="overlay" src="../assets/img/map/joy.png">
    <img id="people" class="overlay" src="../assets/img/map/people.png">
    <img id="places" class="overlay" src="../assets/img/map/places.png">
    <img id="rage" class="overlay" src="../assets/img/map/rage.png">

    <!-- TEXT -->

     <img class="text-layer" src="../assets/img/map/text.png">

    <!-- CLICKABLE HOTSPOTS -->
    
    <div class="hotspot community">
        <<link "">>
            <<set $theme to "community">>
            <<removeclass ".overlay" "active">>
            <<addclass "#community" "active">>
            <<timed 1s>>
                <<goto "community">>
            <</timed>>
        <</link>>
    </div>

    <div class="hotspot history">
        <<link "">>
            <<set $theme to "history">>
            <<removeclass ".overlay" "active">>
            <<addclass "#history" "active">>
            <<timed 1s>>
                <<goto "history">>
            <</timed>>
        <</link>>
    </div>

    <div class="hotspot joy">
        <<link "">>
            <<set $theme to "joy">>
            <<removeclass ".overlay" "active">>
            <<addclass "#joy" "active">>
            <<timed 1s>>
                <<goto "joy">>
            <</timed>>
        <</link>>
    </div>

    <div class="hotspot people">
        <<link "">>
            <<set $theme to "people">>
            <<removeclass ".overlay" "active">>
            <<addclass "#people" "active">>
            <<timed 1s>>
                <<goto "people">>
            <</timed>>
        <</link>>
    </div>

    <div class="hotspot places">
        <<link "">>
            <<set $theme to "places">>
            <<removeclass ".overlay" "active">>
            <<addclass "#places" "active">>
            <<timed 1s>>
                <<goto "places">>
            <</timed>>
        <</link>>
    </div>

    <div class="hotspot rage">
        <<link "">>
            <<set $theme to "rage">>
            <<removeclass ".overlay" "active">>
            <<addclass "#rage" "active">>
            <<timed 1s>>
                <<goto "rage">>
            <</timed>>
        <</link>>
    </div>

</div>


</main>

<<include "footermap">>

:: listaudio [nobr]
<<set _list to $audiodata.filter(a => a && a.theme === $theme)>>

<div class="audio-btn-container">

<<for _audio range _list>>
  <<capture _audio>>
  <div class="audio-btn">
  <img src="assets/img/play.png">

  <<button _audio.audioName>>
    <<set $currentAudio to _audio>>
    <<set $prevpass to $currentAudio.theme>>
    <<goto "listen">>

  <</button>>
  </div>
  <</capture>>
<</for>>

</div>


