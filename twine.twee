:: Story JavaScript [script]
$('#ui-bar').remove();
$(document.head).find('#style-ui-bar').remove();

setup.chooseStoryAudio = () => {

  const audio = document.getElementById("audioPlayer");

  if (!audio) {
    console.error("Audio element not found.");
    return;
  }

  const data = State.variables.currentAudio;

  if (!data) {
    console.warn("No currentAudio set.");
    return;
  }

  // Reset audio
  audio.pause();
  audio.currentTime = 0;

  // ✅ Make this an ARRAY (even for one file)
  const audioFiles = [
    `assets/audio/${data.theme}/${data.audioSrc}.mp3`
  ];

  console.log("audioFiles", audioFiles);

  let currentTrack = 0;

  function playNext() {
    if (currentTrack < audioFiles.length) {
      audio.src = audioFiles[currentTrack];
      console.log("playing audio", audio.src);

      audio.play().catch(err => {
        console.error("Audio play failed:", err);
      });

      currentTrack++;
    }
  }

  // ✅ Prevent stacking
  audio.onended = playNext;

  if (audioFiles.length > 0) {
    playNext();
  }
};




